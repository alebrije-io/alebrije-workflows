{
  "base_images": [
    {
      "image": "python:3.13-slim",
      "use_case": "Python microservices (auth, control-medico, notifications, ai)"
    },
    {
      "image": "node:22-bookworm-slim",
      "use_case": "Node.js/Next.js frontend (alebrije-dashboard)"
    },
    {
      "image": "postgres:16-alpine",
      "use_case": "CI service container for integration tests"
    },
    {
      "image": "redis:7-alpine",
      "use_case": "CI service container for integration tests"
    }
  ],
  "scanning_policy": {
    "block_on_critical": true,
    "report_high": true,
    "ignore_unfixed": true,
    "tool": "trivy"
  },
  "notes": "Always use slim/bookworm-slim/alpine variants. Never use :latest in production Dockerfiles."
}
