{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://alebrije.io/schemas/cadences.enrolled.v1.json",
  "title": "cadences.enrolled v1",
  "description": "Emitted when a contact enters a cadence (new cadence_instance with status='running'). Source publisher: alebrije-mod-cadences-ex.",
  "allOf": [
    { "$ref": "https://alebrije.io/schemas/envelope.v1.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "cadences.enrolled" },
        "data": {
          "type": "object",
          "required": ["cadence_instance_id", "cadence_id", "contact_id", "enrolled_at"],
          "properties": {
            "cadence_instance_id": {
              "type": "string",
              "format": "uuid"
            },
            "cadence_id": {
              "type": "string",
              "format": "uuid"
            },
            "contact_id": {
              "type": "string",
              "format": "uuid"
            },
            "enrolled_at": {
              "type": "string",
              "format": "date-time"
            },
            "enrollment_rule_id": {
              "type": ["string", "null"],
              "format": "uuid",
              "description": "Which rule matched and caused enrollment. Null for manual enrollments."
            },
            "source": {
              "type": ["string", "null"],
              "description": "manual | rule | api | import"
            },
            "metadata": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
