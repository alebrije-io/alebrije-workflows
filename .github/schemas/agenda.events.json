{
  "allOf": [
    {
      "$id": "https://alebrije.io/schemas/agenda.events/appointment_scheduled.json",
      "description": "Emitted when an appointment is scheduled",
      "type": "object",
      "event_type": "appointment_scheduled",
      "required": ["event_type", "data"],
      "properties": {
        "event_type": { "const": "appointment_scheduled" },
        "data": {
          "type": "object",
          "required": ["appointment_id", "user_id", "start_time"],
          "properties": {
            "appointment_id": { "type": "string", "format": "uuid" },
            "user_id": { "type": "string" },
            "start_time": { "type": "string", "format": "date-time" },
            "end_time": { "type": "string", "format": "date-time" },
            "scheduled_at": { "type": "string", "format": "date-time" }
          }
        }
      },
      "examples": [
        {
          "event_type": "appointment_scheduled",
          "data": {
            "appointment_id": "appt_12345",
            "user_id": "usr_cust123",
            "start_time": "2026-05-14T14:00:00Z",
            "end_time": "2026-05-14T15:00:00Z",
            "scheduled_at": "2026-05-07T10:00:00Z"
          }
        }
      ]
    },
    {
      "$id": "https://alebrije.io/schemas/agenda.events/appointment_rescheduled.json",
      "description": "Emitted when an appointment is rescheduled",
      "type": "object",
      "event_type": "appointment_rescheduled",
      "required": ["event_type", "data"],
      "properties": {
        "event_type": { "const": "appointment_rescheduled" },
        "data": {
          "type": "object",
          "required": ["appointment_id", "new_start_time", "old_start_time"],
          "properties": {
            "appointment_id": { "type": "string", "format": "uuid" },
            "new_start_time": { "type": "string", "format": "date-time" },
            "old_start_time": { "type": "string", "format": "date-time" },
            "rescheduled_at": { "type": "string", "format": "date-time" }
          }
        }
      },
      "examples": [
        {
          "event_type": "appointment_rescheduled",
          "data": {
            "appointment_id": "appt_12345",
            "new_start_time": "2026-05-15T10:00:00Z",
            "old_start_time": "2026-05-14T14:00:00Z",
            "rescheduled_at": "2026-05-07T11:00:00Z"
          }
        }
      ]
    },
    {
      "$id": "https://alebrije.io/schemas/agenda.events/appointment_cancelled.json",
      "description": "Emitted when an appointment is cancelled",
      "type": "object",
      "event_type": "appointment_cancelled",
      "required": ["event_type", "data"],
      "properties": {
        "event_type": { "const": "appointment_cancelled" },
        "data": {
          "type": "object",
          "required": ["appointment_id", "reason"],
          "properties": {
            "appointment_id": { "type": "string", "format": "uuid" },
            "reason": { "type": "string" },
            "cancelled_at": { "type": "string", "format": "date-time" }
          }
        }
      },
      "examples": [
        {
          "event_type": "appointment_cancelled",
          "data": {
            "appointment_id": "appt_12345",
            "reason": "customer_request",
            "cancelled_at": "2026-05-07T12:00:00Z"
          }
        }
      ]
    },
    {
      "$id": "https://alebrije.io/schemas/agenda.events/reminder_sent.json",
      "description": "Emitted when a reminder is sent for an appointment",
      "type": "object",
      "event_type": "reminder_sent",
      "required": ["event_type", "data"],
      "properties": {
        "event_type": { "const": "reminder_sent" },
        "data": {
          "type": "object",
          "required": ["appointment_id", "user_id", "channel"],
          "properties": {
            "appointment_id": { "type": "string", "format": "uuid" },
            "user_id": { "type": "string" },
            "channel": { "enum": ["email", "sms", "push"] },
            "sent_at": { "type": "string", "format": "date-time" }
          }
        }
      },
      "examples": [
        {
          "event_type": "reminder_sent",
          "data": {
            "appointment_id": "appt_12345",
            "user_id": "usr_cust123",
            "channel": "sms",
            "sent_at": "2026-05-14T13:30:00Z"
          }
        }
      ]
    }
  ]
}
